@startuml ServerImplementation
!theme plain
skinparam packageStyle rectangle

package "Network" {
  class "ServerBase" {
    +_stop_requested: atomic<bool>
    +_acceptor: tcp::acceptor
    -_host: string
    -_port: uint16_t
    -_io_ctx: io_context&
    -_handler: ClientHandler
    -_ssl_context: shared_ptr<ssl::context>
    +ServerBase(port, io_ctx, handler)
    +host(): string_view
    +port(): uint16_t
    +getIoContext(): io_context&
    +getSslContext(): shared_ptr<ssl::context>
    +stop(): void
    +isStopped(): bool
    +clientHandler(): ClientHandler
  }

  class "ServerSync" {
    +ServerSync(port, io_ctx, handler)
    +listen(): expected<void, error_code>
    +listen_tls(): expected<void, error_code>
    +stop(): void
    #start_accept(promise)
    #start_accept_tls(promise)
  }

  class "ServerAsync" {
    +ServerAsync(port, io_ctx, handler)
    +listen(): awaitable<expected<void, error_code>>
    +listen_tls(): awaitable<expected<void, error_code>>
    +stop(): void
  }

  interface "DualSocket" as DualSocket_IF

  ServerBase <|-- ServerSync
  ServerBase <|-- ServerAsync
  ServerBase --> DualSocket_IF: creates & passes to handler
  
  note right of ServerBase::ClientHandler
    std::function<void(std::unique_ptr<DualSocket>)>
  end note
}
@enduml
